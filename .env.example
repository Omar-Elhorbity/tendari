# ---------------------------------------------------------------------------
# Tendari configuration. Copy to .env and fill in. All values have safe
# defaults for local docker-compose; secrets are optional in demo mode.
#
# NOTE: comments live on their OWN lines. A trailing inline comment after a
# value (e.g. `KEY=   # note`) is read as PART of the value by the settings
# loader — which would turn an "empty" key into a non-empty string and break
# the zero-key mock path. Keep `KEY=` lines bare.
# ---------------------------------------------------------------------------

# --- infra ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/tendari
REDIS_URL=redis://redis:6379/0

# --- LLM provider (swappable: anthropic | openai | mock) ---
# With LLM_PROVIDER=anthropic|openai but NO matching key, the app falls back to
# the deterministic mock provider — so the demo runs with zero external keys.
LLM_PROVIDER=anthropic
# required when LLM_PROVIDER=anthropic (leave empty to use the free mock)
ANTHROPIC_API_KEY=
# required for OpenAI chat AND for real embeddings (leave empty for offline)
OPENAI_API_KEY=
# your chosen current chat model id
CHAT_MODEL=claude-haiku-4-5

# --- embeddings ---
# Anthropic has no embeddings API; embeddings use OpenAI when a key is present,
# otherwise a deterministic offline fallback (lower quality, no key needed).
EMBEDDING_MODEL=text-embedding-3-small
# MUST match EMBEDDING_MODEL and the DB migration
EMBEDDING_DIM=1536

# --- agent engine ---
# hard cap → no runaway tool loops / spend
MAX_AGENT_ITERATIONS=8
# truncate oldest history beyond this many tokens before a call
CONTEXT_TOKEN_BUDGET=12000
# chunks returned by search_help_docs
RETRIEVAL_TOP_K=5

# --- RAG chunking (owned decision: ~800 tokens, 100 overlap) ---
CHUNK_TARGET_TOKENS=800
CHUNK_OVERLAP_TOKENS=100

# --- external side-effecting services (optional in demo mode) ---
# if empty, emails are logged instead of sent
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=support@tendari.example
# test-mode key (sk_test_...); refunds are simulated if empty
STRIPE_SECRET_KEY=

# --- demo seed ---
# Raw key for the seeded demo workspace (only the SHA-256 hash is stored).
# This default is low-entropy and intended for LOCAL demo only — OVERRIDE it
# with a high-entropy value (e.g. output of `python -c "from app.security import
# generate_api_key as g; print(g())"`) before any public/shared deploy.
SEED_API_KEY=demo-key-tendari-001
SEED_WORKSPACE_NAME=Acme Outdoors

# --- pricing override (optional) ---
# JSON map {model: {input_per_1k, output_per_1k}} in USD; overrides built-in
# defaults in app/observability/usage.py. Treat token prices as config.
# Example: LLM_PRICING_JSON={"claude-haiku-4-5":{"input_per_1k":0.001,"output_per_1k":0.005}}
LLM_PRICING_JSON=
